<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="task2.app.mapper.EmployeeMapper">
    
    <!-- ここにSQLを書く 
    id = メソッド名
    resultType = 戻り値の型 
    -->
    <select id="findAll" resultType="task2.app.entity.EmployeeEntity">
        SELECT id, name, age, address FROM employee
    </select>

</mapper>